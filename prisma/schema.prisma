generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String           @id @default(uuid())
  phoneNumber      String           @unique
  verified         Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  avatar           String?
  bio              String?
  name             String?
  email            String?          @unique
  birthday         DateTime?
  timezone         String           @default("UTC")
  meetingTypes     String[]         @default([])
  // Account type: "user" | "verified" | "business" | "agent" | "deleted". Drives badges + Mesh visibility.
  accountType      String           @default("user")
  // Set when the user deletes their account. The row is kept (not hard-deleted) so
  // contacts, moments, and moment requests other users hold onto still resolve —
  // they just see an anonymized "Deleted Account" instead of a dangling reference.
  deletedAt        DateTime?
  // Who can view this profile / book time / see the calendar: "public" | "contacts" | "only_me".
  profileVisibility String          @default("public")
  blockedBy        BlockedContact[] @relation("Blocked")
  blockedUsers     BlockedContact[] @relation("Blocker")
  contactOf        Contact[]        @relation("ContactUser")
  contacts         Contact[]        @relation("UserContacts")
  moments          Moment[]
  receivedRequests MomentRequest[]  @relation("RequestReceiver")
  sentRequests     MomentRequest[]  @relation("RequestSender")
  notifications    Notification[]
  tokens           RefreshToken[]
  devices          UserDevice[]
  availabilitySlots AvailabilitySlot[]
  calendarIntegrations CalendarIntegration[]
  hooks            Hook[]             @relation("UserHooks")
  hookParticipations HookParticipant[] @relation("HookParticipations")
}

model Moment {
  id            Int            @id @default(autoincrement())
  startTime     DateTime
  endTime       DateTime
  availability  String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  allDay        Boolean        @default(false)
  icon          String?
  notes         String?
  visibleTo     String[]       @default([])
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  momentRequest MomentRequest?
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model Contact {
  id            String   @id @default(cuid())
  ownerId       String
  contactUserId String?
  contactPhone  String
  displayName   String
  autoConfirm   Boolean  @default(false)
  updatedAt     DateTime @updatedAt
  importedAt    DateTime @default(now())
  phoneBookId   String?
  createdAt     DateTime @default(now())
  contactUser   User?    @relation("ContactUser", fields: [contactUserId], references: [id])
  owner         User     @relation("UserContacts", fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([ownerId, contactPhone])
}

model MomentRequest {
  id          String   @id @default(cuid())
  senderId    String
  receiverId  String
  startTime   DateTime
  endTime     DateTime
  title       String
  description String?
  meetingType String?  @default("meet")
  locationType String  @default("remote")
  locationLabel String?
  locationAddress String?
  locationLatitude Float?
  locationLongitude Float?
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  momentId    Int?     @unique
  notes       String?
  // Optional source hook this request was created from (meetings are grouped by hook).
  hookId      String?
  moment      Moment?  @relation(fields: [momentId], references: [id])
  hook        Hook?    @relation(fields: [hookId], references: [id])
  receiver    User     @relation("RequestReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  sender      User     @relation("RequestSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([hookId])
}

model BlockedContact {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
}

model Notification {
  id          String    @id @default(cuid())
  userId      String
  type        String
  title       String
  body        String
  data        Json?
  isRead      Boolean   @default(false)
  isDelivered Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  readAt      DateTime?
  deliveredAt DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserDevice {
  id                    String   @id @default(uuid())
  userId                String
  platform              String
  deviceId              String
  appVersion            String
  pushToken             String?
  isActive              Boolean  @default(true)
  rememberMe            Boolean  @default(false)
  lastSeen              DateTime @default(now())
  createdAt             DateTime @default(now())
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@map("user_devices")
}

model ScheduledEvent {
  id           String   @id @default(uuid())
  eventData    String
  scheduledFor DateTime
  status       String   @default("pending")
  attempts     Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([scheduledFor, status])
  @@map("scheduled_events")
}

model EventStore {
  id            String   @id @default(uuid())
  eventType     String
  aggregateId   String
  aggregateType String
  version       Int
  eventData     String
  metadata      Json?
  timestamp     DateTime
  createdAt     DateTime @default(now())

  @@index([aggregateId, aggregateType])
  @@index([eventType])
  @@index([timestamp])
  @@map("event_store")
}

model AvailabilitySlot {
  id           String   @id @default(cuid())
  userId       String
  weekday      Int
  startMinutes Int
  endMinutes   Int
  timezone     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, weekday])
}

model CalendarIntegration {
  id                   String                @id @default(cuid())
  userId               String
  provider             String
  status               String                @default("connected")
  accountEmail         String?
  accountName          String?
  encryptedAccessToken String?
  encryptedRefreshToken String?
  encryptedCredentials String?
  tokenExpiresAt       DateTime?
  lastSyncedAt         DateTime?
  lastSyncStatus       String?
  lastSyncError        String?
  metadata             Json?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  externalEvents       ExternalCalendarEvent[]

  @@unique([userId, provider])
}

model ExternalCalendarEvent {
  id                String              @id @default(cuid())
  integrationId     String
  providerEventId   String
  title             String
  description       String?
  startTime         DateTime
  endTime           DateTime
  isAllDay          Boolean             @default(false)
  location          String?
  sourceCalendarName String?
  providerUpdatedAt DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  integration       CalendarIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([integrationId, providerEventId])
  @@index([startTime, endTime])
}

/// A Hook is the universal scheduling primitive: a reusable template that can
/// represent a meeting, a service, or a listing. Booking flows, Mesh services
/// and paid slots are all built on top of hooks.
model Hook {
  id                String   @id @default(uuid())
  ownerId           String
  title             String
  description       String?
  /// Emoji or icon key shown on the hook card.
  icon              String?
  /// Human label / meeting type, e.g. "Coffee", "Consultation", "Haircut".
  meetingType       String?
  /// Backend/data-science grouping only (Services/Work/Life ...). NOT shown as a UI group.
  category          String?
  /// Access level (see design "Access"): "personal" (only you) | "shared"
  /// (chosen invitees; accepted invitees get the hook in their own My Hooks)
  /// | "private" (one-time use; auto-deleted after the first catch is sent from it)
  /// | "open" (discoverable by anyone who can access your hooks).
  accessLevel       String   @default("personal")
  /// Lifecycle state: "active" | "paused".
  state             String   @default("active")
  /// "remote" | "in_person". in_person reveals the location fields below.
  locationType      String   @default("remote")
  locationLabel     String?
  locationAddress   String?
  locationLatitude  Float?
  locationLongitude Float?
  /// Default meeting duration in minutes for bookings created from this hook.
  durationMinutes   Int      @default(30)
  /// Optional max number of participants (e.g. seminars/group hooks). null = unlimited/1-1.
  capacity          Int?
  isPaid            Boolean  @default(false)
  /// Price in minor units (cents) when isPaid is true.
  priceCents        Int?
  currency          String   @default("USD")
  /// Whether this hook is published to Mesh (only allowed for business accounts).
  publishedToMesh   Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  owner             User                   @relation("UserHooks", fields: [ownerId], references: [id], onDelete: Cascade)
  participants      HookParticipant[]
  availabilitySlots HookAvailabilitySlot[]
  momentRequests    MomentRequest[]

  @@index([ownerId])
  @@index([accessLevel, state])
  @@index([publishedToMesh])
}

/// Per-hook weekly availability (one row per weekday). Mirrors the global
/// AvailabilitySlot but scoped to a hook, with per-day available/pause toggles
/// to match the "Set availability" sheet.
model HookAvailabilitySlot {
  id           String   @id @default(cuid())
  hookId       String
  /// 0 = Sunday ... 6 = Saturday.
  weekday      Int
  startMinutes Int      @default(540)
  endMinutes   Int      @default(1020)
  isAvailable  Boolean  @default(true)
  isPaused     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  hook         Hook     @relation(fields: [hookId], references: [id], onDelete: Cascade)

  @@unique([hookId, weekday])
  @@index([hookId])
}

/// Participants attached to a hook. For "shared" hooks, an invited contact who
/// accepts gets the hook surfaced in their own My Hooks. Supports non-app
/// contacts via contactPhone for invitations.
model HookParticipant {
  id           String   @id @default(cuid())
  hookId       String
  userId       String?
  contactPhone String?
  displayName  String?
  /// "invited" | "accepted" | "declined".
  status       String   @default("invited")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  hook         Hook     @relation(fields: [hookId], references: [id], onDelete: Cascade)
  user         User?    @relation("HookParticipations", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([hookId, userId])
  @@index([userId, status])
  @@index([hookId])
}
